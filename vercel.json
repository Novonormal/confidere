{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/blog/higienizacao-de-sofa-de-luxo-vale-a-pena",
      "destination": "/blog-higienizacao-de-sofa-de-luxo-vale-a-pena.html"
    },
    {
      "source": "/blog/como-preservar-sofas-de-alto-padrao",
      "destination": "/blog-como-preservar-sofas-de-alto-padrao.html"
    },
    {
      "source": "/blog/impermeabilizacao-premium-realmente-funciona",
      "destination": "/blog-impermeabilizacao-premium-realmente-funciona.html"
    },
    {
      "source": "/blog/melhor-custo-beneficio-limpeza-de-sofa",
      "destination": "/blog-melhor-custo-beneficio-limpeza-de-sofa.html"
    },
    {
      "source": "/blog/como-limpar-sofa-gastando-pouco",
      "destination": "/blog-como-limpar-sofa-gastando-pouco.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
